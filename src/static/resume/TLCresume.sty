\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{TLCresume}[11/19/21 resume package]
% Author: Timmy Chan

% Assuming using "article" document class and letter sized paper.
% FONT STUFF

\RequirePackage[T1]{fontenc} %  Font encoding https://texfaq.org/FAQ-why-inp-font
\RequirePackage[default,semibold]{sourcesanspro}
\RequirePackage[11pt]{moresize}
\usepackage{anyfontsize}
\RequirePackage{csquotes}

% LINE SPACING
\linespread{1.025}

% MARGINS AND SPACING
\RequirePackage[margin=0.6in, top=.5in, bottom=1in]{geometry} % Set Margins
\raggedright % left align no indent

% COLOR
\RequirePackage{xcolor}
\definecolor{highlight}{RGB}{0, 102, 179} % Professional resume blue
\definecolor{bodytext}{RGB}{50,50,50} % Slightly gray body text
\AtBeginDocument{\color{bodytext}}



% LINKS
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,urlcolor=highlight}

% BULLET POINTS
\RequirePackage[inline]{enumitem}
\setlength{\tabcolsep}{0in}


% SECTION FORMATTING 
\RequirePackage[nostruts]{titlesec}
\titlespacing*{\section}{0em}{0.7em}{0em}
\titleformat{\section}{
    \color{highlight} \bfseries \scshape \raggedright \normalsize
}{}{0em}{}[\vspace{-1em}{\color{highlight}\hrulefill}]

% SUBSECTION FORMATTING
\titlespacing*{\subsection}{0em}{0em}{0em}
\titleformat{\subsection}{\color{black}\bfseries}{}{0em}{}[]

% CUSTOM SIZE
\newcommand{\mediumsize}{\fontsize{10.5pt}{11pt}\selectfont}

% BOLD COMMAND
\newcommand{\skills}[1]{\textcolor{black}{\textbf{#1}}}

% SUBTEXT
\newcommand{\subtext}[1]{\textit{#1}\par\vspace{-.5em}}

% SUMMARY PARAGRAPH
\newcommand{\summaryparagraph}[1]{
    {\footnotesize\itshape\linespread{1}\selectfont #1\par}
}


% EXPERIENCE HEADER
% \experienceheader{role}{org}{dates}{team (optional)}
\newcommand{\experienceheader}[4]{%
    \subsection{%
        {\mediumsize{#1}}%
        {\normalfont  \textcolor{gray}{\textit{#2}}}%
        \hfill
        {\normalfont \small \textcolor{gray}{#3}}%
    }%
    \ifx&#4&\vspace{1pt}%
    \else
        {\small \textcolor{gray}{\textit{#4}}\par\vspace{-5pt}}%
    \fi
}

% EXPERIENCE SUB-ENTRY (for multiple positions under one role)
% \experiencesubentry{company}{date}
\newcommand{\experiencesubentry}[2]{%
    {\small \textcolor{gray}{\textit{#1}} \hfill {\normalfont #2} \par\vspace{-.5em}}%
}

% tighter spacing than itemize
\setlist[itemize]{align=parleft,left=0pt..1em}
\newenvironment{zitemize}{
\vspace{1pt}
\small\begin{itemize} \itemsep 0pt \parskip 1.75pt \parsep 0pt}
{\end{itemize}\vspace{-2.75pt}}

% NO PAGE NUMBER
\pagenumbering{gobble}

% SUBFILES IMPORTING
\RequirePackage{standalone}

% FOR TEMPLATE FILLER
\RequirePackage[english]{babel}
\RequirePackage{blindtext}% Filler Text
